    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "http-proxy-middleware": "^4.0.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.19",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.0",
